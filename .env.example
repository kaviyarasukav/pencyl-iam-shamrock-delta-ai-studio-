# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DELTA_API_KEY: Required for Delta Exchange Trading Bot operations.
# Configure this via the Secrets panel in the AI Studio UI.
DELTA_API_KEY=""

# DELTA_SECRET_KEY: Required for Delta Exchange Trading Bot operations.
# Configure this via the Secrets panel in the AI Studio UI.
DELTA_SECRET_KEY=""

# DELTA_USE_TESTNET: Set to "false" to use real funds. Defaults to "true" for safety.
DELTA_USE_TESTNET="true"

# ENCRYPTION_KEY: Used for encrypting/decrypting API keys in the SQLite database.
# MUST be set in production to keep user data secure.
ENCRYPTION_KEY="a-very-secret-encryption-key"

# TIMESCALEDB_URL: Optional PostgreSQL/TimescaleDB connection string for historical tick data.
# Example: postgres://user:password@localhost:5432/quant_db
TIMESCALEDB_URL=""
